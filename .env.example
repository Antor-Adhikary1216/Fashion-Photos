# Fashion-Photos environment template
# Copy this file to `.env`, then fill the values marked REQUIRED.

# App runtime
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# REQUIRED: MongoDB Atlas connection string, or keep the local value only if MongoDB is running locally.
MONGO_URI=mongodb://127.0.0.1:27017/fashion_photos

# REQUIRED: Replace both JWT secrets with long random strings, minimum 32 characters.
JWT_SECRET=replace-this-with-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-this-refresh-secret-with-32-characters
JWT_REFRESH_EXPIRES_IN=7d

# Optional defaults
AUTH_COOKIE_MAX_AGE_DAYS=7
BCRYPT_SALT_ROUNDS=12

# REQUIRED for real email verification and password reset emails.
# Gmail users: EMAIL_PASS must be a Gmail App Password, not your normal password.
EMAIL_FROM="Fashion-Photos <no-reply@example.com>"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
SMTP_SECURE=false

# OPTIONAL: Required only if you want admin photo uploads to Cloudinary.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# REQUIRED if you will use MFA. Use a long random string.
MFA_ENCRYPTION_KEY=replace-this-with-a-long-random-encryption-key

# Client API URL
VITE_API_URL=http://localhost:5000/api
